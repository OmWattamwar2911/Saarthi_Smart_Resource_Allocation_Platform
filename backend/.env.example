# Server
NODE_ENV=development
PORT=5000

# Comma-separated list for production, or * for local development
CORS_ORIGIN=http://localhost:5173

# MongoDB Atlas/local URI. Leave empty to run in in-memory mode.
MONGO_URI=

# Optional Gemini key for real AI responses.
# If empty, backend returns deterministic fallback text.
GEMINI_API_KEY=
